# All values are OPTIONAL for local dev. The app runs fully without this file.
PORT=4000

# --- Production (hosting) ---
# Comma-separated list of allowed frontend origins. Leave empty in dev (allows all).
# Example once your frontend is on Vercel:
# ALLOWED_ORIGINS=https://bee-assistant.vercel.app
ALLOWED_ORIGINS=

# Optional: where to store the SQLite file. On Render set this to your
# persistent disk mount, e.g. /var/data/bee.db  (see render.yaml)
# DB_PATH=/var/data/bee.db

# --- Optional local LLM (no API key; Ollama is a local server) ---
USE_OLLAMA=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
